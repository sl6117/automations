# Secrets — never commit real env files
.env
.env.*
!.env.example

# Per-run state (cursors, last-seen ids) — local only
**/state.json

# Logs (cost/token logs, run logs)
logs/*
!logs/.gitkeep

# Node
node_modules/
npm-debug.log*

# OS
.DS_Store

# handoff files
docs/handoffs/

# Compiled crunner binary (rebuilt locally; used by launchd)
/bin/

# CDK build output  (regenerated by every synth)
infra/cdk.out/

# Subscriber list (names, delivery adddresses) - personnal data, local only
**/subscribers.json

.cursor/mcp.json