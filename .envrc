# direnv config for this repo.
# On first entry, direnv will block until you run: direnv allow
# This loads .env (your real secrets) into the shell when you cd here, and unloads on exit.

if [ -f .env ]; then
  dotenv .env
fi

# Make the repo root importable as an absolute path in scripts.
export AUTOMATION_ROOT="$PWD"

# Pin Node 22 for this project if nvm is available.
if command -v nvm >/dev/null 2>&1; then
  nvm use 22 >/dev/null 2>&1 || true
fi
