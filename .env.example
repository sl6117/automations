# Copy this file to .env and fill in real values. NEVER commit .env.
# direnv (via .envrc) loads .env automatically when you cd into this repo.
# --- LLM access ---
# Anthropic (default provider, see config.json). https://console.anthropic.com/
ANTHROPIC_API_KEY=
# OpenRouter (alternative provider). https://openrouter.ai/keys
OPENROUTER_API_KEY=
# --- Twitter / X data source ---
# App bearer token from the X developer console (pay-per-use credits).
X_BEARER_TOKEN=
# Optional: overrides the list id in config.json.
X_LIST_ID=
# --- Delivery: Telegram ---
# Create a bot with @BotFather to get the token.
TELEGRAM_BOT_TOKEN=
# Fallback chat id (per-subscriber ids live in subscribers.json, gitignored).
TELEGRAM_CHAT_ID=
# --- Delivery: email (Resend) ---
RESEND_API_KEY=
# --- AWS (DynamoDB storage backend) ---
# IAM user scoped to the automations table only.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
# Optional: table name override (default "automations").
DYNAMO_TABLE=