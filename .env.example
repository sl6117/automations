# Copy this file to .env and fill in real values. NEVER commit .env.
# direnv (via .envrc) loads .env automatically when you cd into this repo.

# --- LLM access (OpenRouter) ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Default model for summarization. Cheap + good enough for digests.
DIGEST_MODEL=anthropic/claude-haiku-4.5

# --- Delivery: Telegram ---
# Create a bot with @BotFather to get the token.
TELEGRAM_BOT_TOKEN=
# Your chat id (message @userinfobot to find it, or run scripts/telegram-get-chat-id.sh).
TELEGRAM_CHAT_ID=

# --- Twitter / X data source ---
# Which fetch adapter to use: "bird" (real), or "mock" (offline sample data).
FETCH_SOURCE=mock
# The X List id to read (a curated list of serious accounts). Find it in the list URL:
# https://x.com/i/lists/<THIS_NUMBER>
X_LIST_ID=

# --- Run controls ---
# Set to 1 to skip the real LLM call and produce a local heuristic digest (no tokens spent).
DIGEST_DRY_RUN=0
# Where to deliver: "telegram" or "console".
DELIVER_TO=console
